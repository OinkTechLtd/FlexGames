{
  "manifest_version": 3,
  "name": "GoidaX",
  "version": "1.0",
  "description": "Разблокировка сайтов с современным интерфейсом",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["notifications", "storage"],
  "host_permissions": ["<all_urls>"]
}